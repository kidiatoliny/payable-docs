---
import { cn } from '@/lib/utils';
import type { NavGroup } from '@/lib/nav';

interface Props {
  nav: NavGroup[];
  currentSlug: string;
}

const { nav, currentSlug } = Astro.props;
---

<aside class="docs-sidebar">
  <nav>
    {
      nav.map((group) => (
        <div class="docs-sidebar-group">
          <p>{group.label}</p>
          <ul>
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={cn(item.id === currentSlug && 'is-active')}
                  aria-current={item.id === currentSlug ? 'page' : undefined}
                >
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
