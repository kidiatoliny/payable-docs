---
import logo from '@/assets/logo.svg';
import { Search } from '@/components/Search';
import { ThemeToggle } from '@/components/ThemeToggle';
import { MobileNav } from '@/components/MobileNav';
import type { NavGroup } from '@/lib/nav';

interface Props {
  nav: NavGroup[];
  currentSlug?: string;
}

const { nav, currentSlug = '' } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border bg-background/80 backdrop-blur-md">
  <div class="flex h-16 items-center gap-3 px-4 sm:px-6">
    <MobileNav client:load nav={nav} currentSlug={currentSlug} />

    <a href="/" class="flex items-center gap-2.5">
      <img src={logo.src} alt="payable" width="30" height="30" class="rounded-lg" />
      <span class="text-[17px] font-bold tracking-tight">payable</span>
      <span
        class="rounded-full bg-accent px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-accent-foreground"
      >
        Docs
      </span>
    </a>

    <div class="flex flex-1 items-center justify-end gap-1.5">
      <div class="mr-1 flex flex-1 justify-end">
        <Search client:load />
      </div>

      <ThemeToggle client:load />

      <a
        href="https://github.com/akira-io/payable"
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub"
        class="inline-flex size-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"
          ></path>
        </svg>
      </a>

      <a
        href="https://www.npmjs.com/package/@akira-io/payable"
        target="_blank"
        rel="noreferrer"
        aria-label="npm"
        class="inline-flex size-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M2 2v20h20V2H2zm17 17h-3V7h-4v12H5V5h14v14z"></path>
        </svg>
      </a>
    </div>
  </div>
</header>
