---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

{
  items.length > 0 && (
    <aside class="docs-toc">
      <p>On this page</p>
      <ul data-toc>
        {items.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              data-toc-link={heading.slug}
              class:list={[heading.depth === 3 && 'is-nested']}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<script>
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
  if (links.length > 0) {
    const bySlug = new Map(links.map((link) => [link.dataset.tocLink, link]));
    const headings = links
      .map((link) => document.getElementById(link.dataset.tocLink ?? ''))
      .filter((element): element is HTMLElement => element !== null);

    const setActive = (slug: string | undefined) => {
      for (const link of links) {
        const active = link.dataset.tocLink === slug;
        link.classList.toggle('text-foreground', active);
        link.classList.toggle('border-primary', active);
        link.classList.toggle('font-medium', active);
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((entry) => entry.isIntersecting);
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
    );

    for (const heading of headings) observer.observe(heading);
  }
</script>
