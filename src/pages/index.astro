---
import '@/styles/globals.css';
import { getCollection } from 'astro:content';
import { buildNav } from '@/lib/nav';
import { buttonVariants } from '@/components/ui/button';
import Header from '@/components/Header.astro';
import SeoHead from '@/components/SeoHead.astro';
import { heroCode, features, integrations, docCards } from '@/lib/home';

const docs = await getCollection('docs');
const nav = buildNav(docs);

const siteUrl = Astro.site?.href;
const homeTitle = 'payable - the framework-agnostic billing engine for Node.js';
const homeDescription =
  'payable is a framework, provider, storage, and queue agnostic billing engine for Node.js. Wire Stripe, Paddle, or SISP, your storage, and your framework while the core owns checkout, subscriptions, invoices, webhooks, and reconciliation.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'payable docs',
  url: siteUrl,
  description: homeDescription,
  inLanguage: 'en',
  publisher: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: '@akira-io/payable',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Node.js',
  description: homeDescription,
  url: siteUrl,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
};

---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <SeoHead title={homeTitle} description={homeDescription} type="website" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(softwareSchema)}
    />
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header nav={nav} />
    <main class="relative overflow-hidden">
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[560px] bg-[radial-gradient(60%_60%_at_78%_-10%,color-mix(in_oklab,var(--primary)_18%,transparent),transparent)]"
      >
      </div>

      <section class="relative mx-auto grid max-w-6xl items-center gap-12 px-6 pb-16 pt-20 sm:pt-28 lg:grid-cols-2">
        <div>
          <span
            class="inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1 text-xs font-medium text-muted-foreground"
          >
            <span class="size-1.5 rounded-full bg-primary"></span>
            Beta · @akira-io/payable
          </span>
          <h1
            class="mt-5 max-w-xl bg-gradient-to-br from-foreground via-foreground to-primary bg-clip-text text-4xl font-extrabold tracking-tight text-transparent sm:text-5xl lg:text-6xl"
          >
            Billing infrastructure for any Node.js stack
          </h1>
          <p class="mt-5 max-w-xl text-lg text-muted-foreground">
            A framework, provider, storage, and queue agnostic billing engine. The core owns
            checkout, subscriptions, invoices, webhooks, and reconciliation. You bring Stripe or
            Paddle, your database, and your framework.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="/03-getting-started" class={buttonVariants({ size: 'lg' })}>Get started</a>
            <a
              href="https://github.com/akira-io/payable"
              rel="noopener"
              target="_blank"
              class={buttonVariants({ variant: 'outline', size: 'lg' })}
            >
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path
                  d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.3-.5-1.5.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 6 18.3 6.3 18.3 6.3c.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5z"
                />
              </svg>
              View source
            </a>
          </div>
          <div
            class="mt-5 inline-flex items-center gap-3 rounded-lg border border-border bg-card px-4 py-2.5 font-mono text-sm"
          >
            <span class="text-muted-foreground">$</span>
            <span>bun add @akira-io/payable</span>
          </div>
          <dl
            class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted-foreground"
          >
            <div class="flex items-baseline gap-1.5">
              <dt class="font-semibold text-foreground">Node 20+</dt>
              <dd>runtime</dd>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dt class="font-semibold text-foreground">2</dt>
              <dd>core dependencies</dd>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dt class="font-semibold text-foreground">8</dt>
              <dd>optional peers</dd>
            </div>
            <div class="flex items-baseline gap-1.5">
              <dt class="font-semibold text-foreground">TypeScript</dt>
              <dd>first</dd>
            </div>
          </dl>
        </div>

        <div class="relative">
          <div
            class="overflow-hidden rounded-xl border border-border bg-card shadow-[0_24px_70px_-30px_var(--primary)]"
          >
            <div class="flex items-center gap-2 border-b border-border bg-muted/40 px-4 py-3">
              <span class="size-3 rounded-full bg-destructive/70"></span>
              <span class="size-3 rounded-full bg-primary/40"></span>
              <span class="size-3 rounded-full bg-primary/70"></span>
              <span class="ml-2 font-mono text-xs text-muted-foreground">billing.ts</span>
            </div>
            <pre class="overflow-x-auto px-5 py-4 font-mono text-[13px] leading-relaxed"><code set:html={heroCode} /></pre>
          </div>
        </div>
      </section>

      <section class="relative mx-auto max-w-6xl px-6 py-12" aria-labelledby="features-heading">
        <h2 id="features-heading" class="sr-only">Capabilities</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map((feature) => (
              <div class="flex flex-col rounded-xl border border-border bg-card p-5">
                <span class="inline-flex size-10 items-center justify-center rounded-lg border border-border bg-accent text-accent-foreground">
                  <svg
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={feature.path} />
                  </svg>
                </span>
                <span class="mt-4 font-semibold">{feature.title}</span>
                <span class="mt-1.5 text-sm text-muted-foreground">{feature.description}</span>
              </div>
            ))
          }
        </div>
      </section>

      <section class="relative mx-auto max-w-6xl px-6 py-12" aria-labelledby="integrations-heading">
        <div class="rounded-2xl border border-border bg-card/60 px-6 py-8 text-center">
          <h2 id="integrations-heading" class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">
            Wire it into what you already run
          </h2>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            {
              integrations.map((name) => (
                <span class="rounded-full border border-border bg-background px-4 py-1.5 text-sm font-medium">
                  {name}
                </span>
              ))
            }
          </div>
          <p class="mx-auto mt-6 max-w-2xl text-sm text-muted-foreground">
            Every integration is an optional peer dependency. Install only the peers for the
            features you use; the core runtime bundle imports none of them.
          </p>
        </div>
      </section>

      <section class="relative mx-auto max-w-6xl px-6 py-12" aria-labelledby="docs-heading">
        <div class="mb-6 flex items-end justify-between gap-4">
          <h2 id="docs-heading" class="text-2xl font-bold tracking-tight">Explore the documentation</h2>
          <a href="/01-overview" class="text-sm font-medium text-primary hover:underline">All docs</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            docCards.map((card) => (
              <a
                href={card.href}
                class="group flex flex-col rounded-xl border border-border bg-card p-5 transition-all hover:-translate-y-0.5 hover:border-primary/50"
              >
                <span class="inline-flex size-10 items-center justify-center rounded-lg border border-border bg-accent text-accent-foreground">
                  <svg
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={card.path} />
                  </svg>
                </span>
                <span class="mt-4 font-semibold group-hover:text-primary">{card.title}</span>
                <span class="mt-1.5 text-sm text-muted-foreground">{card.description}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="relative mx-auto max-w-6xl px-6 pb-20 pt-6">
        <div
          class="relative overflow-hidden rounded-2xl border border-border bg-card px-8 py-12 text-center"
        >
          <div
            class="pointer-events-none absolute inset-0 bg-[radial-gradient(50%_80%_at_50%_0%,color-mix(in_oklab,var(--primary)_16%,transparent),transparent)]"
          >
          </div>
          <h2 class="relative text-2xl font-bold tracking-tight sm:text-3xl">
            Add billing without lock-in
          </h2>
          <p class="relative mx-auto mt-3 max-w-xl text-muted-foreground">
            Install the package, wire createPayable with your provider, and run a first checkout in
            minutes.
          </p>
          <div class="relative mt-7 flex flex-wrap items-center justify-center gap-3">
            <a href="/03-getting-started" class={buttonVariants({ size: 'lg' })}>Get started</a>
            <a
              href="/04-configuration"
              class={buttonVariants({ variant: 'outline', size: 'lg' })}>Configuration</a
            >
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-border">
      <div
        class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-muted-foreground sm:flex-row"
      >
        <div class="flex items-center gap-2">
          <span class="font-semibold text-foreground">payable</span>
          <span>·</span>
          <span>Beta documentation</span>
        </div>
        <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
          <a href="/01-overview" class="hover:text-foreground">Overview</a>
          <a href="/03-getting-started" class="hover:text-foreground">Getting started</a>
          <a href="/02-architecture" class="hover:text-foreground">Architecture</a>
          <a
            href="https://github.com/akira-io/payable"
            class="hover:text-foreground"
            rel="noopener"
            target="_blank">Source</a
          >
          <a
            href="https://github.com/akira-io"
            class="hover:text-foreground"
            rel="noopener"
            target="_blank">akira-io</a
          >
        </nav>
      </div>
    </footer>
  </body>
</html>
