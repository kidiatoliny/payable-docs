---
import '@/styles/globals.css';
import '@/styles/landing.css';
import SeoHead from '@/components/SeoHead.astro';
import LandingHeader from '@/components/landing/LandingHeader.astro';
import LandingHero from '@/components/landing/LandingHero.astro';
import EngineLifecycle from '@/components/landing/EngineLifecycle.astro';
import LandingFooter from '@/components/landing/LandingFooter.astro';

const siteUrl = Astro.site?.href;
const homeTitle = 'payable - provider-agnostic billing infrastructure for Node.js';
const homeDescription =
  'Build checkout, subscriptions, invoices, webhooks, and reconciliation for Node.js without coupling your application to one provider or framework.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'payable docs',
  url: siteUrl,
  description: homeDescription,
  inLanguage: 'en',
  publisher: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: '@akira-io/payable',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Node.js',
  description: homeDescription,
  url: siteUrl,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead title={homeTitle} description={homeDescription} type="website" />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  </head>
  <body class="landing-page">
    <LandingHeader />
    <main>
      <LandingHero />
      <section class="statement">
        <p>The infrastructure will change. <strong>Your billing model should not.</strong></p>
      </section>
      <EngineLifecycle />
      <section class="closing">
        <div>
          <h2>Node.js billing.<br />Under your control.</h2>
          <p>
            Use the framework, provider, storage, and queue your product needs. Payable keeps the
            billing domain coherent.
          </p>
          <a class="button" href="/03-getting-started">Start building</a>
        </div>
      </section>
    </main>
    <LandingFooter />
  </body>
</html>
