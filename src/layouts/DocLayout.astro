---
import '@/styles/globals.css';
import { getCollection } from 'astro:content';
import { buildNav, flattenNav } from '@/lib/nav';
import Header from '@/components/Header.astro';
import Sidebar from '@/components/Sidebar.astro';
import Toc from '@/components/Toc.astro';
import SeoHead from '@/components/SeoHead.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  slug: string;
}

const { title, description, headings = [], slug } = Astro.props;
const docs = await getCollection('docs');
const nav = buildNav(docs);
const flat = flattenNav(nav);
const index = flat.findIndex((item) => item.id === slug);
const prev = index > 0 ? flat[index - 1] : null;
const next = index >= 0 && index < flat.length - 1 ? flat[index + 1] : null;
const pageTitle = `${title} · payable docs`;
const pageDescription =
  description ?? 'Documentation for the framework-agnostic Node.js billing engine.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: pageDescription,
  url: canonical,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', name: 'payable docs', url: Astro.site?.href },
  author: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
  publisher: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Docs', item: Astro.site?.href },
    { '@type': 'ListItem', position: 2, name: title, item: canonical },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead title={pageTitle} description={pageDescription} type="article" />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <Header nav={nav} currentSlug={slug} />
    <div class="mx-auto flex w-full max-w-[90rem] items-start">
      <Sidebar nav={nav} currentSlug={slug} />
      <main class="min-w-0 flex-1 px-5 py-10 lg:px-12">
        <article class="prose mx-auto max-w-3xl" data-pagefind-body>
          <h1>{title}</h1>
          <slot />
        </article>

        {
          (prev || next) && (
            <nav class="mx-auto mt-12 flex max-w-3xl items-stretch justify-between gap-4 border-t border-border pt-6">
              {prev ? (
                <a href={prev.href} class="group flex flex-1 flex-col rounded-lg border border-border bg-card p-4 transition-colors hover:border-primary/50">
                  <span class="flex items-center gap-1 text-xs text-muted-foreground">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
                    Previous
                  </span>
                  <span class="mt-1 text-sm font-medium group-hover:text-primary">{prev.title}</span>
                </a>
              ) : <span class="flex-1" />}
              {next ? (
                <a href={next.href} class="group flex flex-1 flex-col items-end rounded-lg border border-border bg-card p-4 text-right transition-colors hover:border-primary/50">
                  <span class="flex items-center gap-1 text-xs text-muted-foreground">
                    Next
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                  </span>
                  <span class="mt-1 text-sm font-medium group-hover:text-primary">{next.title}</span>
                </a>
              ) : <span class="flex-1" />}
            </nav>
          )
        }
      </main>
      <Toc headings={headings} />
    </div>
  </body>
</html>
