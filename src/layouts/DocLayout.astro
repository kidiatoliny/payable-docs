---
import '@/styles/globals.css';
import '@/styles/docs.css';
import { getCollection } from 'astro:content';
import { buildNav, flattenNav } from '@/lib/nav';
import Header from '@/components/Header.astro';
import Sidebar from '@/components/Sidebar.astro';
import Toc from '@/components/Toc.astro';
import SeoHead from '@/components/SeoHead.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
  slug: string;
}

const { title, description, headings = [], slug } = Astro.props;
const docs = await getCollection('docs');
const nav = buildNav(docs);
const flat = flattenNav(nav);
const index = flat.findIndex((item) => item.id === slug);
const prev = index > 0 ? flat[index - 1] : null;
const next = index >= 0 && index < flat.length - 1 ? flat[index + 1] : null;
const pageTitle = `${title} · payable docs`;
const pageDescription =
  description ?? 'Documentation for the framework-agnostic Node.js billing engine.';
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: pageDescription,
  url: canonical,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', name: 'payable docs', url: Astro.site?.href },
  author: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
  publisher: { '@type': 'Organization', name: 'akira-io', url: 'https://github.com/akira-io' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Docs', item: Astro.site?.href },
    { '@type': 'ListItem', position: 2, name: title, item: canonical },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead title={pageTitle} description={pageDescription} type="article" forceLight />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(articleSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </head>
  <body class="docs-page">
    <Header nav={nav} currentSlug={slug} />
    <div class="docs-shell">
      <Sidebar nav={nav} currentSlug={slug} />
      <main class="docs-main">
        <article class="prose docs-article" data-pagefind-body>
          <p class="docs-kicker">Payable documentation</p>
          <h1>{title}</h1>
          <aside class="docs-notice">
            <span>Beta</span>
            <p><strong>Beta documentation.</strong> APIs may change before the stable release.</p>
          </aside>
          <slot />
        </article>

        {
          (prev || next) && (
            <nav class="docs-pagination">
              {prev ? (
                <a
                  href={prev.href}
                  class="docs-pagination-link"
                >
                  <span class="docs-pagination-label">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
                    Previous
                  </span>
                  <strong>{prev.title}</strong>
                </a>
              ) : (
                <span class="flex-1" />
              )}
              {next ? (
                <a
                  href={next.href}
                  class="docs-pagination-link is-next"
                >
                  <span class="docs-pagination-label">
                    Next
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                  </span>
                  <strong>{next.title}</strong>
                </a>
              ) : (
                <span class="flex-1" />
              )}
            </nav>
          )
        }
      </main>
      <Toc headings={headings} />
    </div>
  </body>
</html>
